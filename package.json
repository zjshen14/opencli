{
  "name": "@zjshen/opencli",
  "version": "0.1.3",
  "description": "An open-source, model-agnostic AI coding agent CLI — works with any LLM provider",
  "type": "module",
  "bin": {
    "opencli": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cli",
    "ai",
    "agent",
    "gemini",
    "claude",
    "anthropic",
    "coding-agent",
    "ai-agent",
    "llm",
    "developer-tools",
    "code-review",
    "terminal",
    "agentic",
    "model-agnostic",
    "openai",
    "mcp",
    "model-context-protocol"
  ],
  "homepage": "https://github.com/zjshen14/opencli#readme",
  "author": "Zhijie Shen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zjshen14/opencli.git"
  },
  "scripts": {
    "release": "./scripts/publish.sh",
    "prepack": "npm run build",
    "build": "tsup",
    "dev": "tsx --env-file=.env src/cli/index.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:single": "vitest run --reporter=verbose",
    "eval": "vitest run src/eval/matrix.test.ts --reporter=verbose",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@clack/prompts": "^1.4.0",
    "@google/genai": "^2.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "commander": "^14.0.3",
    "diff": "^9.0.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0",
    "openai": "^6.35.0",
    "ora": "^9.4.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
