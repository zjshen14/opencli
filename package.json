{
  "name": "gemini-agent",
  "version": "0.1.0",
  "description": "A general-purpose AI agent CLI powered by Google Gemini",
  "type": "module",
  "bin": {
    "gemini-agent": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx --env-file=.env src/cli/index.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:single": "vitest run --reporter=verbose",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@google/genai": "^1.0.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0",
    "ora": "^8.1.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.2.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
